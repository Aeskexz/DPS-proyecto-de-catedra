# Variables de entorno para el backend
# IMPORTANTE: Copia este archivo como .env y rellena tus valores reales. NO subas .env a Git.

# Base de datos MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=sistema_citas_medicas
DB_PORT=3306

# JSON Web Token
# Genera un string aleatorio largo y seguro para producción
JWT_SECRET=cambia_este_secret_en_produccion_12345
JWT_EXPIRES_IN=8h

# Servidor
PORT=3001
